# Environment Configuration Example
# Copy this file to .env and configure for your environment
# For environment-specific settings, use:
#   - .env.development (local development)
#   - .env.staging (staging environment)
#   - .env.production (production environment)

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Node environment: development, staging, or production
# Affects logging, error handling, and feature flags
NODE_ENV=development

# Server port number
# Default: 3000
PORT=3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL database connection settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=ticketuser
DB_PASSWORD=ticketpass
DB_NAME=support_tickets

# Connection pool settings
# MAX_CONNECTIONS: Maximum number of database connections (10-50 recommended)
# IDLE_TIMEOUT: Time in ms before idle connections are closed (30000ms = 30s)
# CONNECTION_TIMEOUT: Time in ms to wait for connection (10000ms = 10s)
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: debug, info, warn, error
# Development: debug or info
# Staging: info
# Production: info or warn
LOG_LEVEL=info

# Log file location and rotation settings
LOG_FILE_PATH=./logs/app.log
LOG_MAX_FILE_SIZE=10m
LOG_MAX_FILES=7

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# JWT Authentication Settings
# JWT_SECRET: Secret key for signing tokens (MUST be strong in production)
# JWT_EXPIRATION: Token expiration time (e.g., 24h, 8h, 1d)
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRATION=24h

# Authentication Token Validation
# Configure these for your identity provider
AUTH_TOKEN_ISSUER=https://auth.example.com
AUTH_TOKEN_AUDIENCE=support-ticket-app
AUTH_TOKEN_VALIDATION_ENABLED=true

# CORS Configuration
# Single origin or comma-separated list of allowed origins
# Development: http://localhost:3001
# Production: https://yourdomain.com
CORS_ORIGIN=http://localhost:3001

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limit window in milliseconds (900000ms = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window per IP address
# Development: 1000 (relaxed)
# Staging: 500 (moderate)
# Production: 100 (strict)
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# APPLICATION LIMITS
# ============================================================================

# Maximum character lengths for text fields
MAX_TITLE_LENGTH=200
MAX_DESCRIPTION_LENGTH=5000
MAX_COMMENT_LENGTH=2000
MAX_SEARCH_QUERY_LENGTH=200

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable detailed error stack traces (true in dev, false in prod)
ENABLE_ERROR_STACK=true

# Enable request/response logging (useful for debugging)
ENABLE_REQUEST_LOGGING=true

# ============================================================================
# MONITORING AND HEALTH CHECKS (Production)
# ============================================================================

# Enable Prometheus metrics endpoint
ENABLE_METRICS=false
METRICS_PORT=9090

# Health check configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# API URL for frontend application
# This should match your backend API endpoint
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
